---
import Nav from "../components/Nav.astro";
import Footer from "../components/Footer.astro";
import "../styles/global.css";

interface Props {
	title: string;
	description?: string;
	transparentNav?: boolean;
}

const {
	title,
	description = "Sulivan Studios is a moving-image brand studio — strategy, film, and design for brands ready to be seen differently.",
	transparentNav = false,
} = Astro.props;
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content={description} />
		<title>{title} · Sulivan Studios</title>

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link
			href="https://fonts.googleapis.com/css2?family=Archivo:wght@700;800;900&family=Inter:wght@400;500;600;700&display=swap"
			rel="stylesheet"
		/>
	</head>
	<body class="flex min-h-screen flex-col antialiased">
		<Nav transparent={transparentNav} />
		<main class:list={["flex-1", !transparentNav && "pt-20 md:pt-24"]}>
			<slot />
		</main>
		<Footer />
	</body>
</html>
